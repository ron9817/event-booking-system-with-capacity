generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  CONFIRMED
  CANCELLED

  @@map("booking_status")
}

enum WaitlistStatus {
  WAITING
  ALLOCATED
  REMOVED
  EXPIRED

  @@map("waitlist_status")
}

enum AllocationOutboxReason {
  CANCELLED
  CAPACITY_INCREASED

  @@map("allocation_outbox_reason")
}

enum AllocationOutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED

  @@map("allocation_outbox_status")
}

model Event {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  date        DateTime @db.Timestamptz()
  venue       String?  @db.Text
  type        String?  @db.VarChar(50)
  category    String?  @db.VarChar(50)
  duration    String?  @map("duration") @db.Text
  capacity    Int      @default(0)
  bookedCount Int      @default(0) @map("booked_count")
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   String?  @map("created_by") @db.VarChar(255)
  updatedBy   String?  @map("updated_by") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  bookings         Booking[]
  auditLogs        AuditLog[]
  waitlistEntries  WaitlistEntry[]
  allocationOutbox AllocationOutbox[]

  @@index([date], map: "idx_events_upcoming")
  @@map("events")
}

model Booking {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String        @map("event_id") @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId], map: "unique_active_booking")
  @@index([userId], map: "idx_bookings_user_id")
  @@map("bookings")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  opType    String   @map("op_type") @db.VarChar(20)
  eventId   String   @map("event_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  bookingId String?  @map("booking_id") @db.Uuid
  outcome   String   @db.VarChar(20)
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId], map: "idx_audit_event_id")
  @@map("audit_logs")
}

model WaitlistEntry {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String         @map("event_id") @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  positionToken BigInt         @default(dbgenerated("nextval('waitlist_position_seq')")) @map("position_token")
  status        WaitlistStatus @default(WAITING)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  allocatedAt   DateTime?      @map("allocated_at") @db.Timestamptz()
  removedAt     DateTime?      @map("removed_at") @db.Timestamptz()
  version       Int            @default(1)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, status, positionToken], map: "idx_waitlist_next_candidate")
  @@index([userId], map: "idx_waitlist_user_id")
  @@map("waitlist_entries")
}

model AllocationOutbox {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String                 @map("event_id") @db.Uuid
  reason        AllocationOutboxReason
  status        AllocationOutboxStatus @default(PENDING)
  attempts      Int                    @default(0)
  nextAttemptAt DateTime               @default(now()) @map("next_attempt_at") @db.Timestamptz()
  lastError     String?                @map("last_error") @db.Text
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt], map: "idx_outbox_pending")
  @@map("allocation_outbox")
}
