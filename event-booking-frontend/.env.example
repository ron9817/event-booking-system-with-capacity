# API base URL — leave empty in dev (Vite proxy handles it), set in production
VITE_API_URL=

# Backend server URL for Vite dev proxy (dev only, not used in production)
VITE_API_PROXY_TARGET=http://localhost:3000

# Application name (shown in navbar and browser tab)
VITE_APP_NAME=EventBook

# TanStack Query — tune per environment
# Stale time in ms: how long cached data is considered "fresh" (default: 30s)
VITE_QUERY_STALE_TIME_MS=30000
# Retry count for failed queries (default: 1 in dev, 3 in prod recommended)
VITE_QUERY_RETRY_COUNT=1
